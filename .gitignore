# IDE
.idea/
.vscode/

# Terraform – provider binaries & plugin cache (can be 100s of MB)
**/.terraform/
.terraform/

# Terraform lock file is safe to commit, but provider binaries inside are not
# .terraform.lock.hcl  ← intentionally NOT ignored (commit this)

# Terraform state – may contain sensitive data, managed remotely
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log
crash.log
crash.*.log

# Sensitive variable files – never commit secrets
*.tfvars.json
# terraform.tfvars is committed (it has no secrets – secrets use TF_VAR_ env vars)

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# Plan output files
*.tfplan
*.plan
